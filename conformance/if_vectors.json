  "if_id_format": {
    "description": "IF-ID is always exactly 28 characters: 'IF-' (3) + 12 uppercase hex + '-' (1) + 12 uppercase hex.",
    "length": 28,
    "prefix": "IF-",
    "pattern": "IF-[0-9A-F]{12}-[0-9A-F]{12}"
  },
  "receipt_invariants": {
    "description": "These properties MUST hold for any conformant makeReceipt implementation.",
    "invariants": [
      "Same pixels + same receipt fields => same IF-ID (deterministic)",
      "Different pixels => different pixel_digest",
      "Metadata-only change (different byte_digest, same pixels) => same pixel_digest, different receipt_digest, different IF-ID",
      "parent_if_id is null for operation='original'",
      "if_version is always 'IF-CAPTURE-1.0.0'",
      "pixel_sample_stride is 1 for full-resolution receipts",
      "Tampering with any field after receipt creation => verify returns invalid"
    ]
  },
  "canonical_preimage_format": {
    "description": "The pixel_digest preimage is a UTF-8 string of comma-separated 8-bit integers with a trailing comma.",
    "format": "r0,g0,b0,r1,g1,b1,...,rN,gN,bN,",
    "example_single_red_pixel": "255,0,0,",
    "example_two_pixels": "255,0,0,0,0,255,"
  },
